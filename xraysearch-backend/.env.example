# Copy to .env and fill in values

# Model: use google/cxr-foundation if you have HuggingFace access
# Otherwise the default ViT-base works as a proxy
CXR_VIT_MODEL=google/vit-base-patch16-224-in21k

# Public base URL for your X-ray images (S3, Cloudflare R2, etc.)
# Leave blank to skip image_url in API responses
IMAGE_BASE_URL=https://your-bucket.r2.cloudflarestorage.com/xrays

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-xraysearch.vercel.app
